.claude/
__pycache__/
*.pyc

# Audit cache from scripts/audit_venues_external.py
.audit-cache/
venue-audit-external.md
report.csv
email_queue.csv

# Built _site/ (Netlify publish target) — produced fresh on every deploy by
# scripts/build_site.py. Not tracked.
_site/

# Intermediate JOB 7 translation payloads from parallel agent runs.
# Merged into translations/<lang>.json then cleaned up.
translations/agent_*.json

# Cached GTFS zips downloaded by scripts/build_transport_index.py.
# Re-fetched live on each run; the resolved index is data/transport_index.json.
data/_gtfs_cache/

# Cached Overpass/OSM parking pull (scripts/build_parking_index.py).
# Re-fetched live on each run; the resolved index is data/parking_index.json.
data/_osm_cache/

# Source-audit fetch cache (derived, local-only; not a build input)
cache/
data/acceslibre/*.csv

# AXIS local run artifacts (reports are committed under reports/axis/ instead)
.axis/
node_modules/
axis-run.json

# HANDOFF-41 in-session LLM translation work-files (regenerable)
scratchpad/
